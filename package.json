{
  "name": "astral-terminal",
  "productName": "Astral Terminal",
  "productNameShort": "Astral",
  "version": "0.1.0",
  "description": "Terminal multiplexer for AI coding agents on Windows/WSL",
  "private": true,
  "homepage": "https://github.com/wshmkr/astral-terminal",
  "repository": {
    "type": "git",
    "url": "https://github.com/wshmkr/astral-terminal.git"
  },
  "bugs": {
    "url": "https://github.com/wshmkr/astral-terminal/issues"
  },
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "vite build",
    "start": "electron .",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "dist": "vite build && electron-builder",
    "dist:dir": "vite build && electron-builder --dir",
    "release": "vite build && electron-builder --publish always",
    "postinstall": "simple-git-hooks"
  },
  "build": {
    "appId": "net.wshmkr.terminal",
    "productName": "Astral Terminal",
    "directories": {
      "output": "release"
    },
    "electronLanguages": [
      "en-US"
    ],
    "files": [
      "dist/**",
      "package.json",
      "!node_modules/@emotion/**",
      "!node_modules/@mui/**",
      "!node_modules/react/**",
      "!node_modules/react-dom/**",
      "!node_modules/react-icons/**",
      "!node_modules/jetbrains-mono/**",
      "!node_modules/@xterm/xterm/**",
      "!node_modules/@xterm/addon-fit/**",
      "!node_modules/@xterm/addon-web-links/**",
      "!node_modules/node-pty/prebuilds/**",
      "!node_modules/node-pty/deps/**",
      "!node_modules/node-pty/src/**",
      "!node_modules/node-pty/third_party/**",
      "!node_modules/node-pty/build/Release/obj/**",
      "!node_modules/node-pty/build/Release/*.{pdb,lib,exp,ipdb,iobj}"
    ],
    "asarUnpack": [
      "node_modules/node-pty/**"
    ],
    "win": {
      "target": "squirrel",
      "icon": "build/icon.ico"
    },
    "squirrelWindows": {
      "iconUrl": "https://raw.githubusercontent.com/wshmkr/astral-terminal/main/build/icon.ico",
      "loadingGif": "build/install-spinner.gif"
    },
    "publish": {
      "provider": "github",
      "owner": "wshmkr",
      "repo": "astral-terminal"
    }
  },
  "simple-git-hooks": {
    "pre-commit": "npx biome check --staged --no-errors-on-unmatched || { echo; echo 'Hint: run `npm run lint:fix` to auto-fix, then re-stage and commit.'; exit 1; }",
    "pre-push": "npx tsc --noEmit"
  },
  "author": "starlights@wshm.kr",
  "license": "MIT",
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/material": "^9.0.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/headless": "^6.0.0",
    "@xterm/xterm": "^6.0.0",
    "jetbrains-mono": "^1.0.6",
    "node-pty": "^1.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.6.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.12",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "simple-git-hooks": "2.13.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.0"
  }
}
